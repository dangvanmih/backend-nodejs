extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
block main 
  +alert-error(3000)
  +alert-success(3000)
  
  h1(class = "mb-4") Thêm mới sản phẩm

  form(
    action=`${prefixAdmin}/products/create`
    enctype="multipart/form-data"
    id="form-create-product"
    method="POST"
  )
    div(class = "form-group")
      label(for="title") Tên sản phẩm:
      input(
        type="text"
        class ="form-control"
        id = "title"
        name = "title"
        required
      )
    div(class = "form-group")
      label(for="desc") Mô tả:
      textarea(
        type="text"
        class ="form-control texarea-mce"
        id = "desc"
        name = "description"
      )
    div(class = "form-group")
      label(for="price") Giá:
      input(
        type="number"
        class ="form-control"
        id = "price"
        name = "price"
        value = "0"
        min = "0"
        step="0.01"

      )
    div(class = "form-group")
      label(for="price") % Giảm giá:
      input(
        type="number"
        step="0.01"
        class ="form-control"
        id = "price"
        name = "discountPercentage"
        value = "0"
        min = "0"

      )
    div(class = "form-group")
      label(for="stock") Số lượng:
      input(
        type="number"
        class ="form-control"
        id = "stock"
        name = "stock"
        value = "0"
        min = "0"

      )
    div(class = "form-group" upload-image)
      label(for="thumbnail") Ảnh:
      input(
        type="file"
        class ="form-control-file"
        id = "thumbnail"
        name = "thumbnail"
        accept="image/*"
        upload-image-input
      )
      div(class = "d-flex")
        img(
          src=""
          upload-image-preview
          class ="image-preview"
        )
        button(class="btn btn-danger btn-sm d-none " style="height: 30px; margin-top: 10px" close-image) Close

    div(class = "form-group")
      label(for="position") Vị trí:
      input(
        type="text"
        class ="form-control"
        id = "position"
        name = "position"
        min="1"
        placeholder="Tự động tăng"
      )  
    div(class = "form-group form-check form-check-inline")
      input(
        type="radio"
        class ="form-check-input"
        id = "statusActive"
        name = "status"
        value = "active"
        checked
      )
      label(for="statusInactive" class = "form-check-label") Hoạt động:

    div(class = "form-group form-check form-check-inline")
      input(
        type="radio"
        class ="form-check-input"
        id = "statusInactive"
        name = "status"
        value = "inactive"
      )
      label(for="statusInactive" class = "form-check-label") Dừng hoạt động:
    div(class = "form-group")
      button(
        type="submit"
        class = "btn btn-success"
      ) Tạo mới

  script(src = "/admin/js/product.js")

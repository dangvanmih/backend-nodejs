extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
include ../../mixins/select-tree.pug

block main 
  if(role.permission.includes("products_edit"))
    +alert-error(3000)
    +alert-success(3000)
    h1(class="mb-4") Chỉnh sửa sản phẩm
    form(
      action=`${prefixAdmin}/products/edit/${product.id}?_method=PATCH`
      enctype="multipart/form-data"
      id="form-edit-product"
      method="POST"
    )
      div(class="form-group")
        label(for="title") Tên sản phẩm:
        input(
          type="text"
          class="form-control"
          id="title"
          name="title"
          required
          value=product.title
        )
      
      div(class="form-group")
        label(for="products_category_id") Danh mục 
        select(
          name="products_category_id"
          id="products_category_id"
          class="form-control"
        )
          option(value="") -- Chọn danh mục --
          if(category)
            +select-tree(category, 1, product.products_category_id)

      div(class="form-group")
        label(for="desc") Mô tả:
        textarea(
          class="form-control textarea-mce" 
          id="desc"
          name="description"
          rows="5"
        ) #{product.description}

      div(class="form-group")
        label(for="price") Giá:
        input(
          type="number"
          class="form-control"
          id="price"
          name="price"
          value=product.price
          min="0"
          step="any"
        )

      div(class="form-group")
        label(for="discountPercentage") % Giảm giá:
        input(
          type="number"
          step="0.01"
          class="form-control"
          id="discountPercentage"
          name="discountPercentage"
          value=product.discountPercentage
          min="0"
        )

      div(class="form-group")
        label(for="stock") Số lượng:
        input(
          type="number"
          class="form-control"
          id="stock"
          name="stock"
          value=product.stock
          min="0"
        )

      div(class="form-group" upload-image)
        label(for="thumbnail") Ảnh:
        input(
          type="file"
          class="form-control-file"
          id="thumbnail"
          name="thumbnail"
          accept="image/*"
          upload-image-input
        )
        div(class="d-flex mt-2")
          img(
            src=product.thumbnail
            upload-image-preview
            class="image-preview"
            style="width: 150px; height: auto; border: 1px solid #ddd; padding: 5px; border-radius: 5px;"
          )
          button(type="button" class="btn btn-danger btn-sm d-none" style="height: 30px; margin-left: 10px" close-image) x

      div(class="form-group")
        label(for="position") Vị trí:
        input(
          type="number"
          class="form-control"
          id="position"
          name="position"
          min="1"
          placeholder="Tự động tăng"
          value=product.position
        )

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusActive"
          name="status"
          value="active"
          checked=(product.status == "active" ? true : false)
        )
        label(for="statusActive" class="form-check-label") Hoạt động

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusInactive"
          name="status"
          value="inactive"
          checked=(product.status == "inactive" ? true : false)
        )
        label(for="statusInactive" class="form-check-label") Dừng hoạt động

      div(class="form-group")
        button(
          type="submit"
          class="btn btn-success"
        ) Cập nhật

    script(src="/admin/js/product.js")
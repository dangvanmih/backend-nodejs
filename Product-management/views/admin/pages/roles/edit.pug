extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
block main 
  +alert-error(3000)
  +alert-success(3000)
  
  h1(class = "mb-4") Chỉnh sửa nhóm quyền
  form(
    action=`${prefixAdmin}/roles/edit/${records.id}?_method=PATCH`
    method="POST"
  )
    div(class = "form-group")
      label(for="title") Tiêu đề
      input(
        type="text"
        class ="form-control"
        id = "title"
        name = "title"
        value=records.title
        required
      ) 
    div(class = "form-group")
      label(for="desc") Mô tả:
      textarea(
        type="text"
        class ="form-control"
        id = "desc"
        name = "description"
      ) #{records.description}
    div(class = "form-group")
      button(
        type="submit"
        class = "btn btn-success"
      ) Cập nhật
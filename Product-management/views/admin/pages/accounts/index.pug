extends ../../layouts/default.pug
block main 
  if(role.permission.includes("accounts-view"))
    h1(class = "mb-4") Danh sách tài khoản

    .card.mb-3  
      .card-header Danh sách 
      .card-body 
        .row 
          .col-8 
          .col-4.text-right
            if(role.permission.includes("accounts-view_create")) 
              a(
                href=`${prefixAdmin}/accounts/create`
                class="btn btn-outline-success"
              ) + Thêm mới
          table(class ="table table-hover table-sm" )
            thead
              tr
                th STT
                th Avatar
                th Họ tên
                th email
                th Phân quyền
                th Số điện thoại
                th Trạng thái 
                th Hành động
            tbody
              if(records)
                each item,index in records
                  tr
                    td #{index + 1}
                    td 
                      img(src=item.avatar alt=item.fullName width="100px" height = "auto")
                    td #{item.fullName}
                    td #{item.email}
                    td #{item.role.title}
                    td #{item.phone} 
                    td
                      if(role.permission.includes("accounts-view_edit"))
                        if(item.status === "active")
                          a(
                            href="javascript:;" 
                            class = "badge badge-success" 
                            data-status=item.status 
                            button-change-status
                            data-id=item.id
                          ) Hoạt động
                        else 
                          a(
                            href="javascript:;" 
                            class= "badge badge-danger" 
                            data-status=item.status 
                            button-change-status 
                            data-id=item.id
                          ) Không hoạt động
                    td
                      if(role.permission.includes("accounts-view_edit"))
                        a(
                          href=`${prefixAdmin}/accounts/edit/${item.id}` 
                          class = "btn btn-warning btn-sm mr-1" ) Sửa
                      a(
                        href=`${prefixAdmin}/accounts/detail/${item.id}` 
                        class = "btn btn-info btn-sm" ) chi tiết
                      if(role.permission.includes("accounts-view_delete"))
                        button(class = "btn btn-danger btn-sm ml-1" data-id=item.id button-delete) Xóa
              else 
                td(colspan = '4') Chưa có bản ghi nào! 
extends ../../layouts/default.pug

block main
  h1 Trang tổng quan

  .row.mt-4
    //- Thông tin Admin đang đăng nhập
    .col-12
      .card.mb-4
        .card-header Thông tin tài khoản
        .card-body
          if(user.avatar)
            img(src=user.avatar style="width: 100px;margin-bottom: 15px;")
          if(user.fullName)
            p Họ tên: <b>#{user.fullName}</b>
          if(user.email)
            p Email: <b>#{user.email}</b>
          if(role.title)
            p Phân quyền: <b>#{role.title}</b>

    //- Thống kê Danh mục sản phẩm
    .col-md-6.col-lg-3
      .card.mb-4.border-primary
        .card-header.bg-primary.text-white Danh mục sản phẩm
        .card-body
          p Số lượng: <b>#{statistic.category.total}</b>
          p Hoạt động: <b>#{statistic.category.active}</b>
          p Dừng hoạt động: <b>#{statistic.category.inactive}</b>

    //- Thống kê Sản phẩm
    .col-md-6.col-lg-3
      .card.mb-4.border-success
        .card-header.bg-success.text-white Sản phẩm
        .card-body
          p Số lượng: <b>#{statistic.product.total}</b>
          p Hoạt động: <b>#{statistic.product.active}</b>
          p Dừng hoạt động: <b>#{statistic.product.inactive}</b>

    //- Thống kê Tài khoản Admin
    .col-md-6.col-lg-3
      .card.mb-4.border-warning
        .card-header.bg-warning.text-dark Tài khoản Admin
        .card-body
          p Số lượng: <b>#{statistic.account.total}</b>
          p Hoạt động: <b>#{statistic.account.active}</b>
          p Dừng hoạt động: <b>#{statistic.account.inactive}</b>

    //- Thống kê Tài khoản Client
    .col-md-6.col-lg-3
      .card.mb-4.border-danger
        .card-header.bg-danger.text-white Tài khoản Client
        .card-body
          p Số lượng: <b>#{statistic.user.total}</b>
          p Hoạt động: <b>#{statistic.user.active}</b>
          p Dừng hoạt động: <b>#{statistic.user.inactive}</b>
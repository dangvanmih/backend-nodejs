mixin chat-fixed()
  append css
    style.
      .chat-btn-toggle {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        width: 60px;
        height: 60px;
        background: #007bff;
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
      }
      .chat-btn-toggle:hover {
        transform: scale(1.1);
      }

  //- Nút bấm điều hướng
  a(href="/chat" class="chat-btn-toggle")
    i.fa-solid.fa-comment-dots
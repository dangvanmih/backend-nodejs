mixin chat-fixed()
  //- Đẩy CSS vào head của layout
  append css
    style.
      .chat-wrapper {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: sans-serif;
      }
      .chat-btn-toggle {
        width: 60px;
        height: 60px;
        background: #007bff;
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
      }
      .chat-btn-toggle:hover {
        transform: scale(1.1);
      }
      .chat-popup {
        position: absolute;
        bottom: 80px;
        right: 0;
        width: 350px;
        height: 500px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        transform: scale(0);
        transform-origin: bottom right;
        opacity: 0;
        visibility: hidden;
      }
      .chat-popup.show {
        transform: scale(1);
        opacity: 1;
        visibility: visible;
      }
      .chat-header {
        background: #007bff;
        color: white;
        padding: 15px;
        border-radius: 15px 15px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .chat-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background: #f8f9fa;
        display: flex;
        flex-direction: column;
      }
      .inner-incoming .inner-content {
        background: white;
        padding: 8px 12px;
        border-radius: 0 12px 12px 12px;
        max-width: 80%;
        margin-bottom: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        font-size: 14px;
      }
      .chat-footer {
        padding: 15px;
        border-top: 1px solid #eee;
      }
      .chat-footer form {
        display: flex;
        gap: 10px;
      }
      .chat-footer input {
        flex: 1;
        border: 1px solid #ddd;
        padding: 8px 15px;
        border-radius: 20px;
        outline: none;
      }
      .chat-footer button {
        background: #007bff;
        color: white;
        border: none;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        cursor: pointer;
      }
      .btn-close-chat {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
      }

  //- Cấu trúc HTML
  .chat-wrapper
    .chat-popup#chat-popup
      .chat-header
        .d-flex.align-items-center
          img(src="/images/logo-tab.png" width="30" height="30" class="rounded-circle mr-2")
          h6.mb-0.text-white Hỗ trợ trực tuyến
        button.btn-close-chat#btn-close-chat &times;
      
      .chat-body#chat-box
        .inner-incoming
          .inner-content Chào bạn! Shop giày Minhxje có thể giúp gì cho bạn?
        
      .chat-footer
        form#form-chat-fixed
          input(type="text" placeholder="Nhập tin nhắn..." name="content" autocomplete="off")
          button(type="submit")
            i.fa-solid.fa-paper-plane

    button.chat-btn-toggle#chat-btn-toggle
      i.fa-solid.fa-comment-dots

  //- Đẩy Script vào cuối body của layout
  append script
    script.
      document.addEventListener("DOMContentLoaded", () => {
        const btnToggle = document.querySelector("#chat-btn-toggle");
        const btnClose = document.querySelector("#btn-close-chat");
        const chatPopup = document.querySelector("#chat-popup");

        if (btnToggle) {
          btnToggle.addEventListener("click", () => {
            chatPopup.classList.toggle("show");
          });
        }

        if (btnClose) {
          btnClose.addEventListener("click", () => {
            chatPopup.classList.remove("show");
          });
        }
      });
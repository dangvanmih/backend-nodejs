mixin product-item(items)
  .col-xl-3.col-lg-4.col-md-6.col-6.mb-4
            .product-card
              //- Image Area
              .product-image
                a(href=`/products/${items.slug}`)
                  img(src=items.thumbnail alt=items.title)
                //- NHÓM BADGES (SALE & HOT)
                .product-badges
                  if items.featured == "1"
                    .badge-item.badge-hot 
                      img(src="/images/flashsale-hot.png")
                //- Nút tương tác nhanh xuất hiện khi hover
                .product-actions
                  button.btn-action(title="Xem nhanh")
                    i.fa-regular.fa-eye
                  button.btn-add-cart
                    i.fa-solid.fa-cart-plus
                    span Thêm giỏ hàng

                if items.discountPercentage
                  .badge-sale -#{items.discountPercentage}%

              //- Content Area
              .product-info
                //- Thêm category hoặc thương hiệu nhỏ phía trên
                .product-category Figure
                
                h3.product-title 
                  a(href=`/products/${items.slug}`) #{items.title}

                //- Đánh giá sao giả lập
                .product-rating
                  .stars
                    i.fa-solid.fa-star
                    i.fa-solid.fa-star
                    i.fa-solid.fa-star
                    i.fa-solid.fa-star
                    i.fa-solid.fa-star-half-stroke
                  span.sold-count (Đã bán 1.2k)

                .product-price
                  span.price-new #{items.priceNew.toLocaleString('vi-VN')} ₫
                  if items.discountPercentage
                    span.price-old #{items.price.toLocaleString('vi-VN')} ₫
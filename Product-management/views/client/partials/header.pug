include ../mixins/sub-menu.pug
header.header
  .container
    .row.align-items-center
      //- Cột 1: Menu đa cấp (Căn trái)
      .col-6
        nav.inner-menu 
          ul
            li: a(href="/") Trang chủ
            li: a(href="/introduction") Giới Thiệu
            //- Menu Sản phẩm với đầy đủ các mục 1, 1-1, 1-2...
            li.sub-menu
              -const pathProduct ="/products"
              a(href=pathProduct) Sản phẩm
              +sub-menu(layoutProductsCategory,pathProduct)
            li
              a(href="/blog") Blog
            li
              a(href="/contact") Liên Hệ
            li
              a(href="/checkcart") Kiểm tra đơn hàng

      //- Cột 2: Logo (Nằm chính giữa)
      .col-2.text-center
        .inner-logo 
          a(href="/")
            img(src=settingGeneral.logo , alt="logo")

      //- Cột 3: Actions (Căn phải)
      .col-4
        .inner-actions.d-flex.justify-content-end.align-items-center
          .action-search-box
            form(
              action="/search"
              method="GET"
            )
              div(class="form-group d-flex border-0 mb-0 justify-content-end align-items-center")
                input(
                  type="text"
                  name="keyword"
                  class="form-control" 
                  placeholder="Search..."
                  value=keyword  
                )
                button(type="submit")
                  i.fa-solid.fa-magnifying-glass

          .action-auth.mx-3
            a(href="javascript:;") 
              i.fa-regular.fa-circle-user
            //- Menu xổ xuống của User
            if(user)
              ul.inner-menu-user
                li
                  a(href="/user/infoUser") Tài khoản
                li
                  a(href="/chat") Chat
                li
                  a(href="/user/logout") Đăng xuất 
            else
              ul.inner-menu-user
                li
                  a(href="/user/login") Đăng nhập
                li
                  a(href="/user/register") Đăng ký

          .action-cart
            a(href="/cart")
              i.fa-solid.fa-cart-shopping
              span.badge #{miniCart ? miniCart.totalQuantity : "0"}
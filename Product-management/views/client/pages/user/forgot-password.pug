extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block css
  link(rel="stylesheet", href="/css/user.css")

block main
  +alert-error(5000)
  +alert-success(5000)
  
  .container.my-5
    .row.justify-content-center
      .col-lg-5.col-md-8
        .auth-card.shadow-sm.border-0
          .card-body.p-4
            .text-center.mb-4
              //- Icon chìa khóa tạo điểm nhấn
              div.mb-3(style="font-size: 50px; color: #007bff;")
                i.fa-solid.fa-key
              h2.font-weight-bold Quên mật khẩu
              p.text-muted Nhập email của bạn để nhận mã xác thực (OTP) lấy lại mật khẩu

            form(action="/user/password/forgot" method="POST")
              .form-group
                label(for="email") 
                  | Email 
                  span.text-danger *
                input(
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  placeholder="Nhập email đã đăng ký"
                  required
                )

              button(type="submit" class="btn btn-primary btn-block btn-lg shadow-none mt-4") 
                | Gửi mã xác thực
            
            .text-center.mt-4
              p.mb-0 Quay lại 
                a(href="/user/login" class="font-weight-bold text-primary") Đăng nhập
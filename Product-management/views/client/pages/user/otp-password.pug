extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block css
  link(rel="stylesheet", href="/css/user.css")

block main
  +alert-error(5000)
  +alert-success(5000)
  
  .container.my-5
    .row.justify-content-center
      .col-lg-5.col-md-8
        .auth-card.shadow-sm.border-0
          .card-body.p-4
            .text-center.mb-4
              //- Icon đồng hồ hoặc bảo mật
              div.mb-3(style="font-size: 50px; color: #28a745;")
                i.fa-solid.fa-shield-halved
              h2.font-weight-bold Xác thực OTP
              p.text-muted Mã xác thực đã được gửi đến Email của bạn. Mã có hiệu lực trong **3 phút**.

            form(action="/user/password/otp" method="POST")
              .form-group
                label(for="email") Email
                input(
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  value=email
                  readonly
                )
              
              .form-group
                label(for="otp") 
                  | Mã OTP 
                  span.text-danger *
                input(
                  type="text"
                  class="form-control"
                  id="otp"
                  name="otp"
                  placeholder="Nhập 6 chữ số"
                  required
                )

              button(type="submit" class="btn btn-primary btn-block btn-lg shadow-none mt-4") 
                | Xác nhận
            
            .text-center.mt-4
              p.small.text-muted Không nhận được mã? 
                a(href="/user/password/forgot" class="font-weight-bold text-primary") Gửi lại mã